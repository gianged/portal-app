# --- Database ---
DATABASE_URL=postgres://portal:portal@localhost:5432/portal

# --- Redis (sessions, pub/sub, presence, rate limit) ---
REDIS_URL=redis://localhost:6379

# --- Scylla (chat history) ---
SCYLLA_HOSTS=localhost:9042
SCYLLA_KEYSPACE=portal_chat

# --- OpenFGA (ReBAC authorization) ---
# Host port 8088 -> container 8080 (avoids clash with SERVER_PORT=8080).
OPENFGA_API_URL=http://localhost:8088
OPENFGA_STORE_ID=

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
RUST_LOG=info,portal=debug

# --- Local file storage (replaces S3/MinIO) ---
# Files uploaded by users land under this directory on the host machine.
# Configure this to a path outside the repo in production.
STORAGE_ROOT=./storage/uploads
# Public base for presigned download URLs. MUST include the /api/v1 prefix:
# the file-serving route is nested under /api/v1 and sits behind the auth layer,
# so a base without it yields 404s. Point this at your public origin in prod.
STORAGE_PUBLIC_BASE=http://localhost:8080/api/v1

# --- Auth ---
JWT_SECRET=change-me-in-production
SESSION_TTL_HOURS=24

# ============================================================================
# Docker Compose
# ----------------------------------------------------------------------------
# Used ONLY by docker-compose.yml / docker-compose.dev.yml under infra/.
# When running the app on the host (cargo run), the variables ABOVE are what
# matter; the ones below are knobs for the containerized stack.
# ============================================================================

# Postgres credentials inside the stack
POSTGRES_DB=portal
POSTGRES_USER=portal
POSTGRES_PASSWORD=portal

# Backup config — used by `cargo make backup` (infra/scripts/backup.sh), an
# on-demand host script. Archives land in BACKUP_DIR; older than KEEP_DAYS pruned.
BACKUP_DIR=./backups
BACKUP_KEEP_DAYS=7

# Host port overrides — change if a host port is already taken
SERVER_HOST_PORT=8080
FRONTEND_HOST_PORT=80
FRONTEND_DEV_PORT=8081
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
SCYLLA_HOST_PORT=9042
OPENFGA_HTTP_HOST_PORT=8088
OPENFGA_GRPC_HOST_PORT=8089

# Printed by `cargo make bootstrap` (also kept in the portal_openfga-config volume):
#   docker run --rm -v portal_openfga-config:/config alpine cat /config/openfga-store-id
# Paste it below for the host-run (cargo run) flow.
# OPENFGA_STORE_ID=01HXYZ...
