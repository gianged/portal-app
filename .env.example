# --- Database ---
DATABASE_URL=postgres://portal:portal@localhost:5432/portal

# --- Redis (sessions, pub/sub, presence, rate limit) ---
# REDIS_URL must carry the same password as REDIS_PASSWORD.
REDIS_PASSWORD=dev-redis-password
REDIS_URL=redis://:dev-redis-password@localhost:6379

# --- Scylla (chat history) ---
SCYLLA_HOSTS=localhost:9042
SCYLLA_KEYSPACE=portal_chat

# --- OpenFGA (ReBAC authorization) ---
OPENFGA_API_URL=http://localhost:8088
OPENFGA_STORE_ID=
# Token required unless OPENFGA_ALLOW_NO_AUTH=true (local dev only).
OPENFGA_BEARER_TOKEN=
OPENFGA_ALLOW_NO_AUTH=true

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
RUST_LOG=info,portal=debug

# --- Telemetry (server + workers) ---
# LOG_FORMAT: tree | pretty | compact | json (stdout only; file sink is always JSON).
LOG_FORMAT=tree
# OTLP collector endpoint for trace export (e.g. http://localhost:4318); blank = off.
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Resilience (server + workers) ---
HEALTH_PROBE_INTERVAL_SECS=5

# --- Local file storage ---
STORAGE_ROOT=./storage/uploads
# MUST include the /api/v1 prefix or presigned downloads 404.
STORAGE_PUBLIC_BASE=http://localhost:8080/api/v1

# --- Email (workers only) ---
# When false, workers log would-be sends instead of contacting a relay.
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=portal@example.com
# starttls (default) or none.
SMTP_TLS=starttls
PORTAL_BASE_URL=http://localhost:8081

# --- Auth ---
# REQUIRED: random secrets >= 32 bytes (server refuses short/placeholder values).
# Generate each with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
STORAGE_SIGNING_SECRET=change-me-generate-with-openssl-rand-hex-32
SESSION_TTL_HOURS=24

# ============================================================================
# Docker Compose — knobs for the containerized stack under infra/ ONLY.
# For host runs (cargo run), the variables above are what matter.
# ============================================================================

POSTGRES_DB=portal
POSTGRES_USER=portal
POSTGRES_PASSWORD=portal

# OpenFGA <-> its Postgres TLS. Dev: disable; prod: require/verify-full.
OPENFGA_DATASTORE_SSLMODE=disable

# Backup config for `cargo make backup`.
BACKUP_DIR=./backups
BACKUP_KEEP_DAYS=7

# Host port overrides — change if a port is already taken.
SERVER_HOST_PORT=8080
FRONTEND_HOST_PORT=80
FRONTEND_DEV_PORT=8081
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
SCYLLA_HOST_PORT=9042
OPENFGA_HTTP_HOST_PORT=8088
OPENFGA_GRPC_HOST_PORT=8089

# Printed by `cargo make bootstrap`; paste here for host runs.
# OPENFGA_STORE_ID=01HXYZ...
