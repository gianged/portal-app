# Rust build
target/
**/*.rs.bk
Cargo.lock.bak

# Trunk / frontend build artifacts
crates/frontend/dist/
dist/
pkg/

# Env files
.env
.env.local
.env.*.local

# Local file storage (uploaded files stay out of git)
storage/uploads/*
!storage/uploads/.gitkeep

# Runtime logs (server/workers file sink)
logs/

# Database backups (cargo make backup)
/backups/

# Secrets / keys
*.key
*.pem
*.crt

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code settings
.claude/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Reference development files
references/
plans/