  "query": "SELECT\n                 kind AS \"kind: SqlDayOffKind\",\n                 COALESCE(SUM(days), 0)::float8 AS \"days!\"\n               FROM attendance.dayoff\n               WHERE requester_user_id = $1\n                 AND status = 'approved'\n                 AND start_date <= $3\n                 AND end_date >= $2\n               GROUP BY kind",
