  "query": "SELECT\n                 id,\n                 recipient_user_id,\n                 payload AS \"payload: Json<NotificationPayload>\",\n                 read_at,\n                 created_at\n               FROM notification.notifications\n               WHERE recipient_user_id = $1\n                 AND ($2 = false OR read_at IS NULL)\n               ORDER BY created_at DESC\n               LIMIT $3",
