{
  "db_name": "PostgreSQL",
  "query": "SELECT\n                 id,\n                 email,\n                 password_hash,\n                 full_name,\n                 avatar_storage_key,\n                 phone,\n                 timezone,\n                 status            AS \"status: SqlUserStatus\",\n                 system_role       AS \"system_role: SqlSystemRole\",\n                 first_logged_in_at,\n                 deactivated_at,\n                 created_at,\n                 updated_at\n               FROM auth.users\n               WHERE status = $1\n                 AND ($4::text IS NULL OR full_name ILIKE $4 OR email ILIKE $4)\n               ORDER BY created_at\n               LIMIT $2\n               OFFSET $3",
