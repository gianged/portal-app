  "query": "SELECT\n                 id,\n                 owner_group_id,\n                 created_by_user_id,\n                 name,\n                 description,\n                 status AS \"status: SqlProjectStatus\",\n                 progress,\n                 completed_at,\n                 created_at,\n                 updated_at\n               FROM project.projects\n               WHERE owner_group_id = $1\n                 AND ($2::text IS NULL OR name ILIKE $2)\n               ORDER BY created_at DESC",
