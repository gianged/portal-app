{
  "db_name": "PostgreSQL",
  "query": "SELECT\n                 m.id,\n                 m.group_id,\n                 m.user_id,\n                 m.role AS \"role: SqlGroupRole\",\n                 m.joined_at,\n                 m.deactivated_at,\n                 m.version,\n                 m.created_at,\n                 m.updated_at\n               FROM org.memberships m\n               JOIN org.groups g ON g.id = m.group_id AND g.archived_at IS NULL\n               WHERE m.user_id = $1 AND m.deactivated_at IS NULL\n               ORDER BY m.joined_at",
